# Copy this file to .env and fill in your own values

# OneDrive Configuration
ONEDRIVE_CLIENT_ID=your-client-id-here
ONEDRIVE_TENANT=your-tenant-id-here
# This is the name of the OneDrive folder where updated files will be copied into the project input folder. It recursively checks all folders, and is *highly* recommended to use the same folder as the Google Drive backup folder.
ONEDRIVE_REMOTE_FOLDER=GoogleSheetsBackups

# Google Drive configuration
GOOGLE_SHEET_FILE_ID=your-google-sheet-file-id
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Path to your local OneDrive GoogleSheetsBackups folder. This tool works best if you sync OneDrive with local files, and supply the tool with the synced folder
# Mac:     /Users/your-name/Library/CloudStorage/OneDrive-YourOrganization/GoogleSheetsBackups
# Windows: C:\Users\your-name\OneDrive - YourOrganization\GoogleSheetsBackups
ONEDRIVE_BACKUP_DIR=/path/to/your/OneDrive/GoogleSheetsBackups

# Ollama and model configuration. If a model is too slow or causes issues/incorrect outputs, you can change to a different model.
OLLAMA_MODEL_NAME=qwen2.5:3b
ANALYZE_MAX_WORDS=512


# Local paths: you shouldn't need to change any of these unless you want to customize the folder structure,
# or find that the defaults don't work for your system. The tool will create these folders if they don't exist.
ONEDRIVE_DOWNLOAD_DIR=/data/input
ONEDRIVE_TOKEN_CACHE=/data/state/token_cache.bin
ONEDRIVE_MANIFEST=/data/state/onedrive_manifest.xlsx
STATE_DIR=/data/state
ARCHIVE_DIR=/data/archive
HASH_DIR=/data/state/hashes
STATE_FILE=/data/state/google_seen.json
# Baseline (archived previously-ran files) retention mode: all (keep timestamped snapshots) or latest (single baseline only)
# This feature is used for automatic change detection, and latest is recommended to save on storage. 
# If you want to save a complete file history with timestamps, change to "all" and the tool will keep a every copy of changed files in the archive folder.
BASELINE_HISTORY_MODE=latest
# Default Ollama API URL for local deployment. If Ollama is not working locally, you may need to change this
OLLAMA_API_URL=http://host.docker.internal:11434/api/generate

# Set these to pin specific image tags for your deployment.
# Set these to your organization image tags when deploying in your own environment.
WEB_IMAGE=benjenk/agentic-end-to-end-web:v0.4
API_IMAGE=benjenk/agentic-end-to-end-api:v0.4